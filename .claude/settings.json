{
  "permissions": {
    "allow": [
      "Read(**)",
      "Bash(python --version)",
      "Bash(ruff check *)",
      "Bash(black --check *)",
      "Bash(pytest --collect-only *)",
      "Bash(pytest --dry-run *)",
      "Bash(pip list)",
      "Bash(pip show *)",
      "Bash(pip check)",
      "Bash(git status)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git show *)",
      "Bash(git branch *)",
      "Bash(cat *)",
      "Bash(grep *)",
      "Bash(find * -name *)",
      "Bash(wc *)"
    ],
    "deny": [
      "Bash(rm *)",
      "Bash(mv *)",
      "Bash(cp *)",
      "Bash(pip install *)",
      "Bash(pip uninstall *)",
      "Bash(python -m venv *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git reset *)",
      "Bash(git checkout *)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(git tag *)",
      "Bash(sudo *)",
      "Bash(chmod *)",
      "Bash(chown *)",
      "Bash(tee *)"
    ]
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true
  },
  "env": {
    "PYTHONDONTWRITEBYTECODE": "1"
  }
}
